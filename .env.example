# Backend environment variables (set in Render dashboard for fin-autopilot-api service)
GEMINI_API_KEY=get_from_aistudio.google.com

# Set this to your frontend's Render URL so CORS is allowed
# Example: https://fin-autopilot-frontend.onrender.com
CORS_ORIGINS=

# Frontend environment variables (set in Render dashboard for fin-autopilot-frontend service)
# Set this to your backend's Render URL so API calls work
# Example: https://fin-autopilot-api.onrender.com
VITE_API_URL=
